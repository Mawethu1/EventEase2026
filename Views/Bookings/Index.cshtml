@model IEnumerable<EventEase2026.Models.BookingDetailsView>
@{ ViewData["Title"] = "Bookings"; }

<div class="page-head">
    <h1>Bookings</h1>
    <a class="btn btn-primary" asp-action="Create">+ New Booking</a>
</div>

<form method="get" asp-action="Index" class="search-panel app-surface mb-4">
    <div class="filter-grid">
        <div class="form-group">
            <label for="searchTerm">Search</label>
            <input id="searchTerm" class="form-control" type="text" name="searchTerm" value="@ViewData["SearchTerm"]"
                   placeholder="Search by booking #, event, venue, or location..." />
        </div>

        <div class="form-group">
            <label for="eventTypeId">Event Type</label>
            <select id="eventTypeId" class="form-select" name="eventTypeId" asp-items="ViewBag.EventTypes">
                <option value="">All event types</option>
            </select>
        </div>

        <div class="form-group">
            <label for="venueId">Venue</label>
            <select id="venueId" class="form-select" name="venueId" asp-items="ViewBag.Venues">
                <option value="">All venues</option>
            </select>
        </div>

        <div class="form-group">
            <label for="eventStart">Date from</label>
            <input id="eventStart" class="form-control" type="date" name="eventStart" value="@ViewData["EventStart"]" />
        </div>

        <div class="form-group">
            <label for="eventEnd">Date to</label>
            <input id="eventEnd" class="form-control" type="date" name="eventEnd" value="@ViewData["EventEnd"]" />
        </div>

        <div class="form-check filter-checkbox">
            <input id="availableOnly" class="form-check-input" type="checkbox" name="availableOnly" value="true"
                   @(ViewData["AvailableOnly"] as bool? == true ? "checked" : "") />
            <label class="form-check-label" for="availableOnly">Only available venues</label>
            <div class="form-text">Show only available venues.</div>
        </div>
    </div>

    <div class="search-actions">
        <button type="submit" class="btn btn-primary">Search</button>
        <a class="btn btn-outline-secondary btn-sm" asp-action="Index">Reset filters</a>
        <span class="text-muted helper-text">Filters bookings by event type, venue, date, and availability.</span>
    </div>
</form>

@if (!Model.Any())
{
    <p class="muted">No bookings found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>#</th><th>Image</th><th>Venue</th><th>Location</th>
                <th>Event</th><th>Type</th><th>Event Date</th><th>Booking Date</th><th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var b in Model)
        {
            <tr>
                <td>@b.BookingId</td>
                <td>
                    @if (!string.IsNullOrEmpty(b.ImageUrl))
                    {
                        <img src="@b.ImageUrl" alt="@b.VenueName" style="height:48px;border-radius:4px" />
                    }
                </td>
                <td>@b.VenueName</td>
                <td>@b.Location</td>
                <td>@b.EventName</td>
                <td><span class="badge event-type-badge bg-info text-dark">@b.EventTypeName</span></td>
                <td>@b.EventDate.ToString("yyyy-MM-dd HH:mm")</td>
                <td>@b.BookingDate.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@b.BookingId">Cancel</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
