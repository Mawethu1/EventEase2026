@model EventEase2026.Models.Event
@{ ViewData["Title"] = "New Event"; }

<h1>New Event</h1>
<form asp-action="Create" method="post" class="form">
    <div asp-validation-summary="All" class="alert alert-danger mb-3" role="alert"></div>

    <label>Name</label>
    <input asp-for="EventName" />

    <label>Date / Time</label>
    <input asp-for="EventDate" type="datetime-local" />

    <label>Event Type</label>
    <select asp-for="EventTypeId" asp-items="ViewBag.EventTypes">
        <option value="">Select an event type</option>
    </select>

    <label>Description</label>
    <textarea asp-for="Description" rows="3"></textarea>

    <div class="row">
        <button type="submit" class="btn btn-primary">Create</button>
        <a class="btn" asp-action="Index">Cancel</a>
    </div>
</form>
