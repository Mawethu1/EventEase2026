@{ ViewData["Title"] = "Home"; }
<section class="hero hero-grid">
    <div>
        <div class="d-flex align-items-center gap-3 mb-3">
            <img class="hero-logo" src="/images/eventease-logo.png" alt="EventEase logo" />
            <div class="small text-secondary">Do it relaxed</div>
        </div>

        <h1 class="display-6 fw-semibold mb-2">Book venues, manage events.</h1>
        

        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-primary btn-lg" asp-controller="Bookings" asp-action="Create">Create booking</a>
            <a class="btn btn-outline-primary btn-lg" asp-controller="Bookings" asp-action="Index">Search bookings</a>
            <a class="btn btn-light btn-lg" asp-controller="Venues" asp-action="Index">Browse venues</a>
        </div>

        <div class="hero-metrics row g-3 mt-4">
            
           
            <div class="col-12 col-md-4">
                <div class="metric">
                    
                    <div class="metric-sub">Booking with the best.</div>
                </div>
            </div>
        </div>
    </div>

    <div class="hero-side">
        <div class="glass p-4">
            <div class="d-flex align-items-start justify-content-between mb-3">
                <div>
                    <div class="fw-semibold">Today’s actions</div>
                    
                </div>
            </div>

            <div class="d-grid gap-2">
                <a class="btn btn-outline-secondary" asp-controller="Venues" asp-action="Create">Add a venue</a>
                <a class="btn btn-outline-secondary" asp-controller="Events" asp-action="Create">Add an event</a>
                <a class="btn btn-outline-secondary" asp-controller="Bookings" asp-action="Index">View all bookings</a>
            </div>
        </div>

        <div class="row g-3 mt-3">
            
            <div class="col-12">
                <div class="feature card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="fw-semibold mb-1">Smile</div>
                        <div class="text-secondary small">Have a good day!</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
