@model EventEase2026.Models.Venue
@{ ViewData["Title"] = "Edit Venue"; }

<h1>Edit Venue</h1>

<form asp-action="Edit" enctype="multipart/form-data" method="post" class="form">
    <div asp-validation-summary="All" class="alert alert-danger mb-3" role="alert"></div>
    <input type="hidden" asp-for="VenueId" />
    <input type="hidden" asp-for="ImageUrl" />

    <label>Name</label>
    <input asp-for="VenueName" />

    <label>Location</label>
    <input asp-for="Location" />

    <label>Capacity</label>
    <input asp-for="Capacity" type="number" min="1" />

    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <p>Current image:</p>
        <img src="@Model.ImageUrl" alt="current" style="max-width:240px;border-radius:6px" />
    }

    <label>Replace image (optional)</label>
    <input type="file" name="imageFile" accept="image/*" />

    <div class="row">
        <button type="submit" class="btn btn-primary">Save</button>
        <a class="btn" asp-action="Index">Cancel</a>
    </div>
</form>
